# ────────────────────────────────────────────────
#  PromptSite — variáveis de ambiente
#  Copie este arquivo para .env.local e preencha
# ────────────────────────────────────────────────

# ── Neon PostgreSQL ──────────────────────────────
# 1. Acesse: https://console.neon.tech/app/projects/dry-haze-40162562
# 2. Clique em Connect → Show password → copie a string completa

DATABASE_URL=postgresql://neondb_owner:SUA_SENHA@ep-bold-night-ac6me3g0-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require

# ── Stripe ───────────────────────────────────────
# 1. Acesse: https://dashboard.stripe.com/apikeys
# 2. Copie a "Secret key" (começa com sk_live_ ou sk_test_)

STRIPE_SECRET_KEY=sk_test_...

# 3. Crie os 3 produtos em: https://dashboard.stripe.com/products
#    - Starter  → R$ 497  (pagamento único)
#    - Pro      → R$ 997  (pagamento único)
#    - Premium  → R$ 1.997 (pagamento único)
# 4. Em cada produto, clique no preço criado e copie o "Price ID" (price_xxx)

STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# ── URL base (para redirects do Stripe) ──────────
# Em produção, troque pelo seu domínio real

NEXT_PUBLIC_BASE_URL=https://seudominio.com.br
